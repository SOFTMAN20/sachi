# Copy to .env and fill in. Only EXPO_PUBLIC_* vars are exposed to the app.
# Local dev values are printed by `npx supabase start`.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Server-side only (used by the Supabase CLI / edge functions, never shipped to the client):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_SECRET=
